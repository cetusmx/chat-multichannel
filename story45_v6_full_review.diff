-+  async _getApiKey(tenantId) {
-+    const aiConfig = await prisma.aiConfig.findUnique({ where: { tenantId } });
-+    if (!aiConfig) throw new ApiError(404, 'AI configuration not found');
-+    return decrypt(aiConfig.apiKey);
