-+      throw new ApiError(400, 'Invalid Gemini API Key: ' + error.message);
-+    }
-+  }
-+
-+  async generateResponse({ messages, context, tenantId }) {
-+    try {
-+      if (!messages || messages.length === 0) {
-+        throw new ApiError(400, 'Messages array cannot be empty');
