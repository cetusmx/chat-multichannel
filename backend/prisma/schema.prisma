generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  ADMIN
  COORDINATOR
  VENDOR
}

enum DocumentStatus {
  PROCESSING
  READY
  ERROR
}

enum ConversationStatus {
  PENDING_ASSIGNMENT
  ACTIVE
  CLOSED
  ESCALATED
}

enum RoutingStrategy {
  MANUAL
  ROUND_ROBIN
}

enum SenderType {
  CLIENT
  VENDOR
  COORDINATOR
  ADMIN
  IA
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum AttachmentType {
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  domain        String   @unique
  phone         String?
  email         String?
  address       String?
  status        String   @default("active")
  businessHours Json?    @map("business_hours")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  users          User[]
  branches       Branch[]
  whatsappConfig WhatsAppConfig?
  aiConfig       AiConfig?
  assignmentRule AssignmentRule?
  slaConfig      SlaConfig?
  clients        Client[]
  conversations  Conversation[]
  documents      Document[]
  documentChunks DocumentChunk[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groups Group[]

  @@index([tenantId])
  @@map("branches")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  branchId    String   @map("branch_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch  Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  vendors GroupVendor[]

  @@index([branchId])
  @@map("groups")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String    @map("password_hash")
  role         RoleType
  tenantId     String    @map("tenant_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  fcmTokens    String[]  @default([]) @map("fcm_tokens")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  coordinatorId String? @map("coordinator_id")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groups        GroupVendor[]
  coordinator   User?            @relation("UserCoordinator", fields: [coordinatorId], references: [id])
  assignees     User[]           @relation("UserCoordinator")
  conversations Conversation[]   @relation("VendorConversations")
  eligibleRules EligibleVendor[]

  @@index([tenantId])
  @@index([role])
  @@index([coordinatorId])
  @@map("users")
}

model GroupVendor {
  groupId String @map("group_id")
  userId  String @map("user_id")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_vendors")
}

model WhatsAppConfig {
  id                String   @id @default(cuid())
  tenantId          String   @unique @map("tenant_id")
  phoneNumberId     String?  @map("phone_number_id")
  businessAccountId String?  @map("business_account_id")
  accessToken       String?  @map("access_token")
  verifyToken       String?  @map("verify_token")
  webhookUrl        String?  @map("webhook_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("whatsapp_configs")
}

model AssignmentRule {
  id        String          @id @default(cuid())
  tenantId  String          @unique @map("tenant_id")
  strategy  RoutingStrategy @default(MANUAL)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eligibleVendors EligibleVendor[]

  @@map("assignment_rules")
}

model SlaConfig {
  id                String   @id @default(cuid())
  tenantId          String   @unique @map("tenant_id")
  firstResponseMins Int      @default(15) @map("first_response_mins")
  resolutionMins    Int      @default(60) @map("resolution_mins")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sla_configs")
}

model EligibleVendor {
  ruleId String @map("rule_id")
  userId String @map("user_id")

  rule AssignmentRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([ruleId, userId])
  @@index([ruleId])
  @@index([userId])
  @@map("eligible_vendors")
}

model Client {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  phoneNumber String   @map("phone_number")
  name        String?
  profilePic  String?  @map("profile_pic")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isBlocked   Boolean  @default(false) @map("is_blocked")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, phoneNumber])
  @@index([tenantId])
  @@map("clients")
}

model Conversation {
  id                  String             @id @default(cuid())
  tenantId            String             @map("tenant_id")
  clientId            String             @map("client_id")
  vendorId            String?            @map("vendor_id")
  status              ConversationStatus @default(PENDING_ASSIGNMENT)
  aiPendingEscalation Boolean            @default(false) @map("ai_pending_escalation")
  lastMessageAt       DateTime           @default(now()) @map("last_message_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vendor   User?     @relation("VendorConversations", fields: [vendorId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([tenantId, createdAt])
  @@index([clientId])
  @@index([vendorId])
  @@map("conversations")
}

model Message {
  id             String         @id @default(cuid())
  conversationId String         @map("conversation_id")
  senderType     SenderType     @map("sender_type")
  senderId       String?        @map("sender_id") // ID del User si es VENDOR o SYSTEM.
  content        String?        @db.Text
  waMessageId    String?        @unique @map("wa_message_id")
  tags           String[]       @default([])
  isInternal     Boolean        @default(false) @map("is_internal")
  status         MessageStatus?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]

  @@index([conversationId])
  @@index([senderId])
  @@index([waMessageId])
  @@index([conversationId, senderType, createdAt])
  @@map("messages")
}

model Attachment {
  id        String         @id @default(cuid())
  messageId String         @map("message_id")
  type      AttachmentType
  url       String         @db.Text
  mimeType  String?        @map("mime_type")
  size      Int?
  name      String?
  createdAt DateTime       @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

model AiConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique @map("tenant_id")
  provider  String   @default("gemini")
  apiKey    String   @map("api_key") // Encrypted
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model Document {
  id        String         @id @default(cuid())
  filename  String
  size      Int
  status    DocumentStatus @default(PROCESSING)
  tenantId  String         @map("tenant_id")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([tenantId])
  @@map("documents")
}

model DocumentChunk {
  id         String                     @id @default(uuid())
  text       String                     @db.Text
  embedding  Unsupported("vector(768)")
  documentId String                     @map("document_id")
  tenantId   String                     @map("tenant_id")
  createdAt  DateTime                   @default(now()) @map("created_at")
  updatedAt  DateTime                   @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([tenantId])
  @@map("document_chunks")
}
