   IA
   SYSTEM
 }
@@ -54,8 +62,11 @@ model Tenant {
   users         User[]
   branches      Branch[]
   whatsappConfig WhatsAppConfig?
+  aiConfig      AiConfig?
   clients       Client[]
   conversations Conversation[]
